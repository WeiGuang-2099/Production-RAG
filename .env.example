# ── LLM Configuration ──────────────────────────────────
LLM_PROVIDER=openai                    # Supported: openai, anthropic
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxx                     # Get from https://platform.openai.com/api-keys
# LLM_BASE_URL=                        # Optional: custom endpoint
# LLM model routing: cheap model for the agent's control-plane calls (route/grade/rewrite),
# strong model (LLM_MODEL) for generation; same-provider fallback on error/timeout.
LLM_MODEL_FAST=gpt-4o-mini
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_TIMEOUT=30

# ── Embedding Configuration ────────────────────────────
EMBEDDING_PROVIDER=openai              # Supported: openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=                  # Optional

# ── Reranker Configuration ─────────────────────────────
RERANKER_PROVIDER=cohere               # Supported: cohere, none
RERANKER_MODEL=rerank-v3.5
COHERE_API_KEY=xxx                     # Get from https://dashboard.cohere.com/

# ── Graph Extraction ───────────────────────────────────
GRAPH_EXTRACTOR=llm                    # Supported: llm, nlp, none

# ── Qdrant Vector Database ─────────────────────────────
QDRANT_URL=http://localhost:6333       # Use 'qdrant' hostname inside Docker
COLLECTION_NAME=rag_docs
# QDRANT_API_KEY=                      # Optional: for authenticated instances

# ── LangSmith Observability ────────────────────────────
LANGSMITH_API_KEY=xxx                  # Get from https://smith.langchain.com/
LANGSMITH_PROJECT=production-rag
LANGSMITH_TRACING=true

# ── Generation ─────────────────────────────────────────
PROMPT_MODE=grounded                   # grounded (cite + refuse) | basic (legacy, for A/B)
AGENT_MAX_REWRITES=2                    # /agent corrective-RAG max query rewrites

# ── Cache ──────────────────────────────────────────────
CACHE_ENABLED=false                    # true = skip retrieval+generation on repeated/similar queries
CACHE_SIMILARITY_THRESHOLD=0.95        # cosine threshold for a semantic cache hit (0.0-1.0)

# ── Chunking Strategy ──────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval Settings ─────────────────────────────────
RETRIEVAL_MODE=hybrid                  # hybrid (vector + BM25 RRF) | dense (vector only)
QUERY_TRANSFORM=none                   # none | multi_query (paraphrase + fuse) | hyde
TOP_K=5
RERANK_TOP_K=3

# ── Storage ────────────────────────────────────────────
DATA_DIR=./data

# ── Security ───────────────────────────────────────────
# SHA256 hash of your API bearer token (empty = no auth)
API_KEY_HASH=
CORS_ORIGINS=*                         # Comma-separated allowed origins
MAX_FILE_SIZE_MB=100                   # Max file size for ingestion (MB)

# ── Guardrails ─────────────────────────────────────────
GUARDRAILS_ENABLED=true                 # input injection block + output PII redaction + toxicity flag
